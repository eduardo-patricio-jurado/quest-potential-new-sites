{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run CLI",
            "type": "shell",
            "command": "python -m src.cli",
            "args": ["${input:locationFile}"],
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "locationFile",
            "type": "promptString",
            "description": "Path to Excel file with coordinates",
            "default": "locations.xlsx"
        }
    ]
}
